# Appwrite Configuration — copy to .env.local and fill in your values
VITE_APPWRITE_ENDPOINT=https://nyc.cloud.appwrite.io/v1
VITE_APPWRITE_PROJECT_ID=your-project-id
VITE_APPWRITE_DATABASE_ID=laboutiquerd
VITE_APPWRITE_BUCKET_ID=media

# Collections
VITE_APPWRITE_PRODUCTS_COLLECTION=products
VITE_APPWRITE_OFFERS_COLLECTION=offers
