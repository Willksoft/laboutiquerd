# Appwrite Configuration — copy to .env.local and fill in your values
VITE_APPWRITE_ENDPOINT=https://nyc.cloud.appwrite.io/v1
VITE_APPWRITE_PROJECT_ID=your-project-id
VITE_APPWRITE_DATABASE_ID=laboutiquerd
VITE_APPWRITE_BUCKET_ID=media

# Collections
VITE_APPWRITE_PRODUCTS_COLLECTION=products
VITE_APPWRITE_OFFERS_COLLECTION=offers
VITE_APPWRITE_ORDERS_COLLECTION=orders
VITE_APPWRITE_RESERVATIONS_COLLECTION=reservations
VITE_APPWRITE_BRAID_MODELS_COLLECTION=braid-models
VITE_APPWRITE_BRAID_SERVICES_COLLECTION=braid-services
VITE_APPWRITE_VENDORS_COLLECTION=vendors
VITE_APPWRITE_TSHIRT_PRESETS_COLLECTION=tshirt-presets
VITE_APPWRITE_BRANDS_COLLECTION=brands
VITE_APPWRITE_SITE_CONTENT_COLLECTION=site-content
VITE_APPWRITE_CATEGORIES_COLLECTION=categories
VITE_APPWRITE_SERVICES_COLLECTION=header-services

# Server-side only (not exposed to browser) — for seed scripts & admin tasks
APPWRITE_API_KEY=your-api-key
